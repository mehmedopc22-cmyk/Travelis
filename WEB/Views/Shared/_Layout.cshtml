<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WEB</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WEB.styles.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Comfortaa:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/Style/assets_css_travelis.tokens.css" />
    <link rel="stylesheet" href="~/css/Style/assets_css_travelis.components.css" />
    <link rel="stylesheet" href="~/css/Style/assets_css_travelis.page.css" />

</head>
<body>
    <header>
        <nav class="tv-navbar navbar navbar-expand-lg sticky-top">
            <div class="container">
                <div class="tv-navbar-shell d-flex align-items-center justify-content-between w-100">

                    <a asp-action="Index" asp-controller="Home" class="tv-brand-pill d-flex align-items-center text-decoration-none">
                        <img src="https://cdn-icons-png.flaticon.com/512/2972/2972185.png"
                             style="height:20px; filter:brightness(0) invert(1); " alt="Travelis Logo">
                        <span>Travelis</span>
                    </a>

                    <button class="navbar-toggler tv-navbar-toggler"
                            type="button"
                            data-bs-toggle="collapse"
                            data-bs-target="#tvMainNav"
                            aria-controls="tvMainNav"
                            aria-expanded="false"
                            aria-label="Превключване на навигацията">
                        <i class="fa-solid fa-bars"></i>
                    </button>

                    <div class="collapse navbar-collapse justify-content-end mt-3 mt-lg-0" id="tvMainNav">

                        <ul class="navbar-nav align-items-lg-center gap-lg-2 me-lg-4">
                            <li class="nav-item">
                                <a class="nav-link tv-nav-link" asp-action="Index" asp-controller="Hotel">
                                    <i class="fa-solid fa-hotel me-1"></i> Хотели
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link tv-nav-link" href="../cars/cars-home.html">
                                    <i class="fa-solid fa-car me-1"></i> Rent-a-car
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link tv-nav-link" href="../taxi/taxi-home.html">
                                    <i class="fa-solid fa-taxi me-1"></i> Такси
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link tv-nav-link active" asp-action="Apply" asp-controller="Hotel">
                                    <i class="fa-solid fa-handshake"></i></i> Стани партньор
                                </a>
                            </li>
                        </ul>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <div class="d-flex align-items-center gap-2 mb-2 mb-lg-0 flex-nowrap">
                                <a class="tv-btn-login" asp-action="Profile" asp-controller="Account">
                                    <i class="fa-regular fa-circle-user me-1"></i> Профил
                                </a>
                            </div>
                        }
                        else
                        {
                            <div class="d-flex align-items-center gap-2 mb-2 mb-lg-0 flex-nowrap">
                                <a class="tv-btn-login" asp-action="Login" asp-controller="Account">
                                    <i class="fa-regular fa-circle-user me-1"></i> Вход
                                </a>
                            </div>
                        }
                        </div>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="tv-glass-soft mt-auto border-0 rounded-0 border-top border-secondary border-opacity-25 py-4">
        <div class="container">
            <div class="d-flex flex-column flex-md-row align-items-center justify-content-between gap-3">
                <div class="small text-secondary">
                    &copy; 2025 Travelis.bg. Всички права запазени.
                </div>
                <div class="d-flex gap-3">
                    <a href="#" class="text-secondary text-decoration-none small hover-white">Помощ</a>
                    <a href="#" class="text-secondary text-decoration-none small hover-white">Условия</a>
                    <a href="#" class="text-secondary text-decoration-none small hover-white">Поверителност</a>
                </div>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
