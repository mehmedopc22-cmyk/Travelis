@model List<Domain.Entities.RoleEntity>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Потребителски роли";

    var systemRoles = Model.Where(r => r.Name == "Administrator" || r.Name == "GlobalAdmin").ToList();
    var managementRoles = Model.Where(r => r.Name == "HotelAdmin").ToList();
    var userRoles = Model.Where(r => r.Name == "User").ToList();
}

<!-- SYSTEM ROLES -->
@if (systemRoles.Any())
{
    <div class="mb-5">
        <h4 class="text-danger fw-bold mb-3">Системни роли</h4>

        <div class="row g-4">
            @foreach (var role in systemRoles)
            {
                <div class="col-md-6 col-xl-4">
                    <div class="tv-role-card ">
                        <h5 class="fw-bold text-white mb-2">@role.Name</h5>
                        <p class="text-white-50 small mb-4 flex-grow-1">@role.Description</p>

                        <div class="small text-white-50">
                            Създадена: @role.CreatedAt.ToString()
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

<!-- MANAGEMENT -->
@if (managementRoles.Any())
{
    <div class="mb-5">
        <h4 class="text-warning fw-bold mb-3">Управляващи роли</h4>

        <div class="row g-4">
            @foreach (var role in managementRoles)
            {
                <div class="col-md-6 col-xl-4">
                    <div class="tv-role-card ">
                        <h5 class="fw-bold text-white mb-2">@role.Name</h5>
                        <p class="text-white-50 small mb-4 flex-grow-1">@role.Description</p>

                        <div class="small text-white-50">
                            Създадена: @role.CreatedAt.ToString()
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

<!-- USERS -->
@if (userRoles.Any())
{
    <div class="mb-5">
        <h4 class="text-info fw-bold mb-3">Потребители</h4>

        <div class="row g-4">
            @foreach (var role in userRoles)
            {
                <div class="col-md-6 col-xl-4">
                    <div class="tv-role-card ">
                        <h5 class="fw-bold text-white mb-2">@role.Name</h5>
                        <p class="text-white-50 small mb-4 flex-grow-1">@role.Description</p>

                        <div class="small text-white-50">
                            Създадена: @role.CreatedAt.ToString()
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}