@model List<Domain.Entities.HotelEntity>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Моите хотели";
}

<div class="d-flex justify-content-between align-items-end mb-4 flex-wrap gap-3">
    <div>
        <h2 class="fw-bold mb-1">Моите хотели</h2>
        <p class="text-white-50 mb-0">
            Назначени хотели: <span class="text-white fw-bold">@Model.Count</span>
        </p>
    </div>
</div>

@if (!Model.Any())
{
    <div class="tv-card p-4">
        <div class="text-white fw-bold mb-1">Нямаш назначен хотел</div>
        <div class="text-white-50 small">Глобален администратор трябва да те назначи към одобрен хотел.</div>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var hotel in Model)
        {
            <div class="col-12 col-md-6 col-xl-4">
                <div class="tv-card p-4 h-100">
                    <h5 class="fw-bold text-white mb-1">@hotel.Name</h5>
                    <div class="small text-white-50 mb-3">
                        <i class="fa-solid fa-location-dot me-1"></i>
                        @hotel.City, @hotel.Country
                    </div>

                    <div class="small text-white-50 mb-3">@hotel.Email</div>

                    <a asp-controller="HotelAdmin" asp-action="Manage" asp-route-hotelId="@hotel.Id" class="btn tv-btn-primary w-100">
                        <i class="fa-solid fa-pen-to-square me-1"></i> Управлявай
                    </a>
                </div>
            </div>
        }
    </div>
}
