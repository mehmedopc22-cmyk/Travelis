@model WEB.Models.HotelIndexViewModel

@{
    ViewData["Title"] = "Хотели";
    string sortBy = Model.Filters.SortBy;
}

<div class="container">
    <div id="aiLoadingOverlay"
         class="position-fixed top-0 start-0 w-100 h-100 d-none align-items-center justify-content-center"
         style="z-index: 2000; background: rgba(2, 6, 23, 0.72); backdrop-filter: blur(6px);">
        <div class="tv-glass-card p-4 text-center" style="max-width: 340px;">
            <div class="spinner-border text-info mb-3" role="status" aria-hidden="true"></div>
            <div class="text-white fw-bold">AI филтърът работи</div>
            <div class="text-white-50 small mt-1">Изчакваме локалния модел да анализира хотелите.</div>
        </div>
    </div>

    <section class="tv-hero-section pt-0 pb-5">
        <div class="tv-hotels-hero">
            <div class="tv-hotels-hero-inner row align-items-center g-4">
                <div class="col-lg-7">
                    <span class="tv-hotels-hero-badge mb-2">
                        <i class="fa-solid fa-map-location-dot"></i>
                        @(string.IsNullOrWhiteSpace(Model.Filters.Destination) ? "Всички дестинации" : Model.Filters.Destination)
                    </span>
                    <h1 class="tv-hotels-hero-title mb-2">@Model.DestinationTitle</h1>
                    <p class="tv-hotels-hero-sub mb-0">@Model.TotalCount намерени обекта.</p>
                </div>
                <div class="col-lg-5 text-lg-end">
                    <a class="tv-btn-primary text-decoration-none" href="#hotelFilters">
                        <i class="fa-solid fa-pen-to-square me-2"></i> Промени
                    </a>
                </div>
            </div>
        </div>
    </section>

    <div class="row g-4 g-xl-5 align-items-start">

        <aside class="col-12 col-xl-4 col-xxl-3">

            <div class="d-flex d-xl-none justify-content-between align-items-center mb-3">
                <button class="tv-mobile-filter-btn" type="button" data-bs-toggle="offcanvas" data-bs-target="#tvFiltersOffcanvas">
                    <i class="fa-solid fa-sliders"></i> Филтри
                </button>
                <span class="tv-results-count small">
                    @Model.TotalCount обекта
                </span>
            </div>

            @if (TempData["AiFilterMessage"] is string aiFilterMessage)
            {
                <div class="alert alert-info py-2 mb-3">
                    @aiFilterMessage
                </div>
            }
            @if (ViewData["AiFilterMessage"] is string aiFilterViewMessage)
            {
                <div class="alert alert-info py-2 mb-3">
                    @aiFilterViewMessage
                </div>
            }
            @if (TempData["AiFilterError"] is string aiFilterError)
            {
                <div class="alert alert-danger py-2 mb-3">
                    @aiFilterError
                </div>
            }

            <div class="d-none d-xl-block tv-filter-shell sticky-xl-top" style="top: 100px;" id="hotelFilters">
                <form asp-action="Index" method="get" class="tv-filter-panel">

                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="tv-filter-title-main">Филтри за хотели</div>
                            <div class="tv-filter-sub">Избери дестинация, цена и подредба.</div>
                        </div>
                        <a class="btn btn-link p-0 tv-filter-sub text-decoration-none" asp-action="Index">Изчисти всички</a>
                    </div>

                    <div class="tv-filter-section">
                        <label class="tv-filter-label" for="destination">Дестинация</label>
                        <div class="tv-input-group">
                            <input id="destination"
                                   name="Destination"
                                   value="@Model.Filters.Destination"
                                   class="tv-input w-100"
                                   placeholder="София, Варна, хотел..." />
                            <span class="tv-input-icon"><i class="fa-solid fa-location-dot"></i></span>
                        </div>
                    </div>

                    <div class="tv-filter-section">
                        <div class="tv-filter-label">Цена за нощувка</div>
                        <div class="row g-2">
                            <div class="col-6">
                                <label class="tv-filter-meta" for="minPrice">От</label>
                                <input id="minPrice"
                                       name="MinPrice"
                                       value="@Model.Filters.MinPrice"
                                       class="tv-input w-100"
                                       type="number"
                                       min="0"
                                       step="10"
                                       placeholder="50" />
                            </div>
                            <div class="col-6">
                                <label class="tv-filter-meta" for="maxPrice">До</label>
                                <input id="maxPrice"
                                       name="MaxPrice"
                                       value="@Model.Filters.MaxPrice"
                                       class="tv-input w-100"
                                       type="number"
                                       min="0"
                                       step="10"
                                       placeholder="600" />
                            </div>
                        </div>
                    </div>

                    <div class="tv-filter-section">
                        <label class="tv-filter-label" for="sortBySidebar">Сортирай</label>
                        <select id="sortBySidebar" name="SortBy" class="form-select bg-dark text-white border-secondary">
                            <option value="recommended" selected='@(sortBy == "recommended")'>Препоръчани</option>
                            <option value="name" selected='@(sortBy == "name")'>Име</option>
                            <option value="city" selected='@(sortBy == "city")'>Град</option>
                            <option value="price_asc" selected='@(sortBy == "price_asc")'>Цена (Ниска &rarr; Висока)</option>
                            <option value="price_desc" selected='@(sortBy == "price_desc")'>Цена (Висока &rarr; Ниска)</option>
                        </select>
                    </div>

                    <div class="tv-filter-section pt-3">
                        <div class="d-flex tv-filter-footer-btns">
                            <button class="tv-btn-primary flex-grow-1" type="submit">
                                Приложи филтри
                            </button>
                        </div>
                    </div>
                </form>

                <form asp-action="AiFilter" method="post" class="tv-filter-panel mt-3 js-ai-filter-form">
                    @Html.AntiForgeryToken()

                    <div class="tv-filter-section">
                        <div class="tv-filter-label">
                            <i class="fa-solid fa-robot me-1"></i> AI филтър
                        </div>
                        <label class="tv-filter-meta mb-1" for="aiLocation">Локация</label>
                        <input id="aiLocation"
                               name="SelectedLocation"
                               value="@Model.Filters.Destination"
                               class="tv-input w-100 mb-3"
                               required
                               placeholder="Напр. София, Варна, Банско" />
                        <div class="tv-filter-meta mb-2">Опиши какъв хотел търсиш.</div>
                        <textarea name="Prompt"
                                  class="tv-input w-100"
                                  rows="4"
                                  required
                                  placeholder="Напр. евтин хотел в центъра, под 120 лв, най-ниска цена"></textarea>
                    </div>

                    <button class="tv-btn-glass w-100 justify-content-center" type="submit">
                        <span class="js-ai-button-content">
                            <i class="fa-solid fa-robot"></i> AI филтър
                        </span>
                    </button>
                </form>
            </div>

            <div class="offcanvas offcanvas-end tv-offcanvas-filters d-xl-none" tabindex="-1" id="tvFiltersOffcanvas">
                <div class="offcanvas-header">
                    <h5 class="offcanvas-title text-white">Филтри</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Затвори"></button>
                </div>
                <div class="offcanvas-body">
                    <form asp-action="Index" method="get" class="tv-filter-panel">
                        <div class="tv-filter-section">
                            <label class="tv-filter-label" for="mobileDestination">Дестинация</label>
                            <div class="tv-input-group">
                                <input id="mobileDestination"
                                       name="Destination"
                                       value="@Model.Filters.Destination"
                                       class="tv-input w-100"
                                       placeholder="София, Варна, хотел..." />
                                <span class="tv-input-icon"><i class="fa-solid fa-location-dot"></i></span>
                            </div>
                        </div>

                        <div class="tv-filter-section">
                            <div class="tv-filter-label">Цена за нощувка</div>
                            <div class="row g-2">
                                <div class="col-6">
                                    <label class="tv-filter-meta" for="mobileMinPrice">От</label>
                                    <input id="mobileMinPrice"
                                           name="MinPrice"
                                           value="@Model.Filters.MinPrice"
                                           class="tv-input w-100"
                                           type="number"
                                           min="0"
                                           step="10"
                                           placeholder="50" />
                                </div>
                                <div class="col-6">
                                    <label class="tv-filter-meta" for="mobileMaxPrice">До</label>
                                    <input id="mobileMaxPrice"
                                           name="MaxPrice"
                                           value="@Model.Filters.MaxPrice"
                                           class="tv-input w-100"
                                           type="number"
                                           min="0"
                                           step="10"
                                           placeholder="600" />
                                </div>
                            </div>
                        </div>

                        <div class="tv-filter-section">
                            <label class="tv-filter-label" for="mobileSortBy">Сортирай</label>
                            <select id="mobileSortBy" name="SortBy" class="form-select bg-dark text-white border-secondary">
                                <option value="recommended" selected='@(sortBy == "recommended")'>Препоръчани</option>
                                <option value="name" selected='@(sortBy == "name")'>Име</option>
                                <option value="city" selected='@(sortBy == "city")'>Град</option>
                                <option value="price_asc" selected='@(sortBy == "price_asc")'>Цена (Ниска &rarr; Висока)</option>
                                <option value="price_desc" selected='@(sortBy == "price_desc")'>Цена (Висока &rarr; Ниска)</option>
                            </select>
                        </div>

                        <div class="tv-filter-section pt-3">
                            <button class="tv-btn-primary w-100" type="submit">
                                Приложи филтри
                            </button>
                            <a class="tv-btn-glass w-100 mt-2 text-decoration-none justify-content-center" asp-action="Index">
                                Изчисти всички
                            </a>
                        </div>
                    </form>

                    <form asp-action="AiFilter" method="post" class="tv-filter-panel mt-3 js-ai-filter-form">
                        @Html.AntiForgeryToken()

                        <div class="tv-filter-section">
                            <div class="tv-filter-label">
                                <i class="fa-solid fa-robot me-1"></i> AI филтър
                            </div>
                            <label class="tv-filter-meta mb-1" for="mobileAiLocation">Локация</label>
                            <input id="mobileAiLocation"
                                   name="SelectedLocation"
                                   value="@Model.Filters.Destination"
                                   class="tv-input w-100 mb-3"
                                   required
                                   placeholder="Напр. София, Варна, Банско" />
                            <div class="tv-filter-meta mb-2">Опиши какъв хотел търсиш.</div>
                            <textarea name="Prompt"
                                      class="tv-input w-100"
                                      rows="4"
                                      required
                                      placeholder="Напр. евтин хотел в центъра, под 120 лв, най-ниска цена"></textarea>
                        </div>

                        <button class="tv-btn-glass w-100 justify-content-center" type="submit">
                            <span class="js-ai-button-content">
                                <i class="fa-solid fa-robot"></i> AI филтър
                            </span>
                        </button>
                    </form>
                </div>
            </div>
        </aside>

        <div class="col-12 col-xl-8 col-xxl-9">

            <div class="tv-grid-toolbar">
                <div class="d-flex align-items-center gap-3">
                    <div class="tv-view-switcher">
                        <button class="tv-view-btn" type="button" aria-label="List View">
                            <i class="fa-solid fa-list"></i>
                        </button>
                        <button class="tv-view-btn active" type="button" aria-label="Grid View">
                            <i class="fa-solid fa-border-all"></i>
                        </button>
                    </div>
                    <span class="text-white-50 small">
                        Показани @(Model.TotalCount == 0 ? 0 : 1)-@Model.TotalCount от @Model.TotalCount
                    </span>
                </div>

                <form asp-action="Index" method="get" class="d-flex align-items-center gap-2">
                    <input type="hidden" name="Destination" value="@Model.Filters.Destination" />
                    <input type="hidden" name="MinPrice" value="@Model.Filters.MinPrice" />
                    <input type="hidden" name="MaxPrice" value="@Model.Filters.MaxPrice" />
                    <label class="text-white-50 small me-1" for="sortByToolbar">Сортирай:</label>
                    <select id="sortByToolbar"
                            name="SortBy"
                            class="form-select form-select-sm bg-dark text-white border-secondary"
                            style="width: auto; border-radius: 20px;"
                            onchange="this.form.submit()">
                        <option value="recommended" selected='@(sortBy == "recommended")'>Препоръчани</option>
                        <option value="name" selected='@(sortBy == "name")'>Име</option>
                        <option value="city" selected='@(sortBy == "city")'>Град</option>
                        <option value="price_asc" selected='@(sortBy == "price_asc")'>Цена (Ниска &rarr; Висока)</option>
                        <option value="price_desc" selected='@(sortBy == "price_desc")'>Цена (Висока &rarr; Ниска)</option>
                    </select>
                </form>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.AiResponse))
            {
                <div class="tv-glass-card p-4 mb-3">
                    <div class="d-flex align-items-center gap-2 mb-2 text-info fw-bold">
                        <i class="fa-solid fa-robot"></i>
                        AI отговор
                    </div>
                    <p class="text-white-50 mb-0">@Model.AiResponse</p>
                </div>
            }

            <div class="vstack gap-3 tv-hotels-results">
                @if (Model.Hotels.Any())
                {
                    foreach (var hotel in Model.Hotels)
                    {
                        <partial name="_HotelCardPartial" model="hotel" />
                    }
                }
                else
                {
                    <div class="alert alert-info rounded-4">
                        Няма намерени хотели.
                    </div>
                }
            </div>

        </div>
    </div>

</div>

@section Scripts {
    <script>
        document.querySelectorAll(".js-ai-filter-form").forEach((form) => {
            form.addEventListener("submit", () => {
                if (!form.checkValidity()) {
                    return;
                }

                const overlay = document.getElementById("aiLoadingOverlay");
                overlay?.classList.remove("d-none");
                overlay?.classList.add("d-flex");

                form.querySelectorAll("button[type='submit']").forEach((button) => {
                    button.setAttribute("disabled", "disabled");
                    const content = button.querySelector(".js-ai-button-content");
                    if (content) {
                        content.innerHTML = '<span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span> AI филтърът работи';
                    }
                });
            });
        });
    </script>
}
