@model WEB.Models.BookingViewModel
@{
    ViewData["Title"] = "Резервация на кола под наем - Travelis";
    
    var selectedLocation = Context.Request.Query["location"].ToString();
    var pAuto = Context.Request.Query["p_auto"].ToString();
    var pClass = Context.Request.Query["p_class"].ToString();
    var pHybrid = Context.Request.Query["p_hybrid"].ToString();
}

<main class="tv-main-hotels">
    <div class="container">
        <!-- HERO / STEP HEADER -->
        <section class="tv-hero-section pt-4 pb-4 pt-lg-5">
            <div class="row g-4 align-items-center">
                <div class="col-lg-8">
                    <div class="tv-hotels-hero position-relative overflow-hidden">
                        <!-- ORBS -->
                        <div class="tv-orb tv-orb-sky"></div>
                        <div class="tv-orb tv-orb-indigo"></div>
                        <div class="tv-hotels-hero-inner">
                            <span class="tv-hotels-hero-badge mb-2">
                                <i class="fa-solid fa-car-side me-1"></i> Rent-a-car · Стъпка 1 от 2
                            </span>
                            <h1 class="tv-hotels-hero-title mb-1">
                                Данни за наема
                            </h1>
                            <p class="tv-hotels-hero-sub">
                                Изберете локация, дати, часове и допълнителни услуги за вашата резервация.
                            </p>
                            <div class="d-flex flex-wrap gap-2 mt-3">
                                <span class="tv-chip-pill">
                                    <i class="fa-solid fa-circle-check text-success me-1"></i> Безплатна отмяна по повечето оферти
                                </span>
                                <span class="tv-chip-pill">
                                    <i class="fa-solid fa-shield-halved me-1"></i> Прозрачни застраховки
                                </span>
                                <span class="tv-chip-pill">
                                    <i class="fa-solid fa-road me-1"></i> Вкл. километри в цената
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- STEPPER -->
                <div class="col-lg-4">
                    <div class="tv-card-panel h-100">
                        <div class="tv-stepper">
                            <div class="tv-stepper-item active">
                                <div class="tv-step-circle">1</div>
                                <div class="tv-step-body">
                                    <div class="tv-step-title">Данни за наема</div>
                                    <div class="tv-step-sub">Локация, дати, допълнителни услуги</div>
                                </div>
                            </div>
                            <div class="tv-stepper-divider"></div>
                            <div class="tv-stepper-item">
                                <div class="tv-step-circle">2</div>
                                <div class="tv-step-body">
                                    <div class="tv-step-title">Детайли и плащане</div>
                                    <div class="tv-step-sub">Шофьор, договор, потвърждение</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
        <!-- MAIN LAYOUT -->
        <section class="pb-5">
            <div class="row g-4 align-items-start">
                <!-- LEFT: BOOKING FORM -->
                <div class="col-lg-8">
                    <!-- 1. ЛОКАЦИЯ И ДАТИ -->
                    <div class="tv-card-panel mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div>
                                <h2 class="tv-section-title mb-1">1. Локация и дати</h2>
                                <p class="tv-filter-sub mb-0">
                                    Определете откъде и кога ще вземете и върнете автомобила.
                                </p>
                            </div>
                            <span class="badge rounded-pill bg-sky-500 text-slate-950 small d-none d-md-inline-flex">
                                <i class="fa-solid fa-plane-arrival me-1"></i> Идеално за полети
                            </span>
                        </div>
                        <form method="post" action="/Cars/BookingStepOne" class="row g-3">
                            <!-- Pickup location -->
                            <div class="col-12">
                                <label class="small text-secondary fw-bold ms-2 mb-1">
                                    Локация за вземане
                                </label>
                                <div class="tv-input-wrapper">
                                    <i class="fa-solid fa-location-dot tv-input-icon"></i>
                                    <input asp-for="PickUpLocation"
                                           id="pickupLoc"
                                           class="tv-input"
                                           type="text"
                                           value="@selectedLocation"
                                           placeholder="Летище София (SOF)..."
                                           required />
                                </div>
                                <div class="d-flex flex-wrap gap-2 mt-2 small text-white-50">
                                    <button class="tv-chip-toggle @(selectedLocation == "София Център" ? "active" : "")" type="button">
                                        София Център
                                    </button>
                                    <button class="tv-chip-toggle @(selectedLocation == "SOF Терминал 2" ? "active" : "")" type="button">
                                        SOF Терминал 2
                                    </button>
                                    <button class="tv-chip-toggle @(selectedLocation == "Пловдив летище" ? "active" : "")" type="button">
                                        Пловдив летище
                                    </button>
                                </div>
                            </div>
                            <!-- Pickup date & time -->
                            <div class="col-md-6">
                                <label class="small text-secondary fw-bold ms-2 mb-1">
                                    Дата на вземане
                                </label>
                                <div class="tv-input-wrapper">
                                    <i class="fa-solid fa-calendar-day tv-input-icon"></i>
                                    <input asp-for="PickUpDate"
                                           class="tv-input"
                                           type="date"
                                           value="@Model.PickUpDate.ToString("yyyy-MM-dd")"
                                           required />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="small text-secondary fw-bold ms-2 mb-1">
                                    Час на вземане
                                </label>
                                <div class="tv-input-wrapper">
                                    <i class="fa-solid fa-clock tv-input-icon"></i>
                                    <input name="PickupTime" class="tv-input" type="time" value="10:00" />
                                </div>
                            </div>
                            <!-- Return location toggle -->
                            <div class="col-12">
                                <div class="form-check form-switch d-flex align-items-center gap-2 mt-1">
                                    <input name="DifferentReturnLocation" class="form-check-input" id="diffDropSwitch" type="checkbox" />
                                    <label class="form-check-label small text-white-50" for="diffDropSwitch">
                                        Различна локация за връщане (напр. вземане София, връщане Варна)
                                    </label>
                                </div>
                            </div>
                            <!-- Return location -->
                            <div class="col-12">
                                <label class="small text-secondary fw-bold ms-2 mb-1">
                                    Локация за връщане
                                </label>
                                <div class="tv-input-wrapper">
                                    <i class="fa-solid fa-location-crosshairs tv-input-icon"></i>
                                    <input asp-for="DropOffLocation" class="tv-input" placeholder="Същата като вземане или друга локация" type="text" />
                                </div>
                            </div>
                            <!-- Return date & time -->
                            <div class="col-md-6">
                                <label class="small text-secondary fw-bold ms-2 mb-1">
                                    Дата на връщане
                                </label>
                                <div class="tv-input-wrapper">
                                    <i class="fa-solid fa-calendar-check tv-input-icon"></i>
                                    <input asp-for="DropOffDate"
                                           class="tv-input"
                                           type="date"
                                           value="@Model.DropOffDate.ToString("yyyy-MM-dd")"
                                           required />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="small text-secondary fw-bold ms-2 mb-1">
                                    Час на връщане
                                </label>
                                <div class="tv-input-wrapper">
                                    <i class="fa-solid fa-clock-rotate-left tv-input-icon"></i>
                                    <input name="ReturnTime" class="tv-input" type="time" value="10:00" />
                                </div>
                            </div>
                            <!-- Driver age -->
                            <div class="col-md-6">
                                <label class="small text-secondary fw-bold ms-2 mb-1">
                                    Възраст на шофьора
                                </label>
                                <div class="tv-input-wrapper">
                                    <i class="fa-solid fa-user tv-input-icon"></i>
                                    <select asp-for="DriverAge" class="tv-input">
                                        <option value="young">18 – 24 години</option>
                                        <option value="standard">25 – 70 години</option>
                                        <option value="senior">71+ години</option>
                                    </select>
                                </div>
                                <p class="small text-white-50 mt-1 mb-0">
                                    При възраст &lt; 25 или &gt; 70 г. може да има допълнителна такса.
                                </p>
                            </div>
                            <!-- Residency -->
                            <div class="col-md-6">
                                <label class="small text-secondary fw-bold ms-2 mb-1">
                                    Държава на пребиваване
                                </label>
                                <div class="tv-input-wrapper">
                                    <i class="fa-solid fa-flag tv-input-icon"></i>
                                    <select asp-for="Residence" class="tv-input">
                                        <option value="Bulgaria">България</option>
                                        <option value="EU">Държава от ЕС</option>
                                        <option value="UK">Великобритания</option>
                                        <option value="USA">САЩ / Канада</option>
                                        <option value="Other">Друга държава</option>
                                    </select>
                                </div>
                            </div>
                        </form>
                    </div>
                    <!-- 2. ПРЕДПОЧИТАНИЯ ЗА АВТОМОБИЛА -->
                    <input type="hidden" name="CarCategory" id="selectedCategory" value="Sedan" />
                    <input type="hidden" name="Transmission" id="selectedTransmission" value="Automatic" />
                    <div class="tv-card-panel mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div>
                                <h2 class="tv-section-title mb-1">2. Предпочитания за автомобила</h2>
                                <p class="tv-filter-sub mb-0">
                                    Не променя избрания автомобил, но помага на партньора да предложи най-подходящия клас.
                                </p>
                            </div>
                        </div>
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="small text-secondary fw-bold ms-2 mb-2">
                                    Клас и тип
                                </label>
                                <div class="d-flex flex-wrap gap-2">
                                    <button class="tv-chip-toggle @(pClass == "sedan" ? "active" : "")" type="button">Седан</button>
                                    <button class="tv-chip-toggle @(pClass == "hatchback" ? "active" : "")" type="button">Хечбек</button>
                                    <button class="tv-chip-toggle @(pClass == "suv" ? "active" : "")" type="button">SUV</button>
                                    <button class="tv-chip-toggle @(pClass == "van" ? "active" : "")" type="button">Ван</button>
                                </div>
                            </div>
                            <div class="col-12">
                                <label class="small text-secondary fw-bold ms-2 mb-2">
                                    Скоростна кутия и гориво
                                </label>
                                <div class="d-flex flex-wrap gap-2">
                                    <button class="tv-chip-toggle @(pAuto == "True" ? "active" : "")" type="button">Автоматик</button>
                                    <button class="tv-chip-toggle @(pAuto == "False" ? "active" : "")" type="button">Ръчна</button>
                                    <button class="tv-chip-toggle @(pHybrid == "True" ? "active" : "")" type="button">Хибрид / Електрическа</button>
                                    <button class="tv-chip-toggle @(pAuto == "True" ? "active" : "")" type="button">Дизел</button>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- 3. ДОПЪЛНИТЕЛНИ УСЛУГИ -->
                    <div class="tv-card-panel mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div>
                                <h2 class="tv-section-title mb-1">3. Допълнителни услуги</h2>
                                <p class="tv-filter-sub mb-0">
                                    Добавете детски столчета, GPS, втори шофьор, зимно оборудване и др.
                                </p>
                            </div>
                        </div>
                        <div class="row g-3">
                            <!-- child seats -->
                            <div class="col-md-6">
                                <div class="tv-extra-item d-flex align-items-start gap-3">
                                    <div class="form-check mt-1">
                                        <input name="HasChildSeat" class="form-check-input" id="extraChildSeat" type="checkbox" />
                                    </div>
                                    <div>
                                        <label class="form-check-label text-white fw-semibold" for="extraChildSeat">
                                            Детско столче
                                        </label>
                                        <p class="small text-white-50 mb-1">
                                            Одобрено по EU стандарт, подходящо за 9м – 4г.
                                        </p>
                                        <div class="small text-info">
                                            + €5 / ден
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- GPS -->
                            <div class="col-md-6">
                                <div class="tv-extra-item d-flex align-items-start gap-3">
                                    <div class="form-check mt-1">
                                        <input name="HasGPS" class="form-check-input" id="extraGPS" type="checkbox" />
                                    </div>
                                    <div>
                                        <label class="form-check-label text-white fw-semibold" for="extraGPS">
                                            GPS навигация
                                        </label>
                                        <p class="small text-white-50 mb-1">
                                            Офлайн карти за България и Балканите.
                                        </p>
                                        <div class="small text-info">
                                            + €3 / ден
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- Additional driver -->
                            <div class="col-md-6">
                                <div class="tv-extra-item d-flex align-items-start gap-3">
                                    <div class="form-check mt-1">
                                        <input name="HasAdditionalDriver" class="form-check-input" id="extraDriver" type="checkbox" />
                                    </div>
                                    <div>
                                        <label class="form-check-label text-white fw-semibold" for="extraDriver">
                                            Втори шофьор
                                        </label>
                                        <p class="small text-white-50 mb-1">
                                            Позволява още един водач в договора за наем.
                                        </p>
                                        <div class="small text-info">
                                            + €15 / резервация
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- Winter pack -->
                            <div class="col-md-6">
                                <div class="tv-extra-item d-flex align-items-start gap-3">
                                    <div class="form-check mt-1">
                                        <input name="HasWinterPack" class="form-check-input" id="extraWinter" type="checkbox" />
                                    </div>
                                    <div>
                                        <label class="form-check-label text-white fw-semibold" for="extraWinter">
                                            Зимен пакет (вериги, стъргалка и др.)
                                        </label>
                                        <p class="small text-white-50 mb-1">
                                            Препоръчително за планински дестинации и зимни курорти.
                                        </p>
                                        <div class="small text-info">
                                            + €20 / резервация
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- Cross-border -->
                            <div class="col-md-6">
                                <div class="tv-extra-item d-flex align-items-start gap-3">
                                    <div class="form-check mt-1">
                                        <input name="HasCrossBorder" class="form-check-input" id="extraBorder" type="checkbox" />
                                    </div>
                                    <div>
                                        <label class="form-check-label text-white fw-semibold" for="extraBorder">
                                            Разрешение за пътуване в чужбина
                                        </label>
                                        <p class="small text-white-50 mb-1">
                                            Изисква се за Румъния, Гърция, Сърбия. Подлежи на одобрение.
                                        </p>
                                        <div class="small text-info">
                                            + €35 / резервация
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- Wi-Fi -->
                            <div class="col-md-6">
                                <div class="tv-extra-item d-flex align-items-start gap-3">
                                    <div class="form-check mt-1">
                                        <input name="HasWifi" class="form-check-input" id="extraWifi" type="checkbox" />
                                    </div>
                                    <div>
                                        <label class="form-check-label text-white fw-semibold" for="extraWifi">
                                            Мобилен Wi-Fi рутер
                                        </label>
                                        <p class="small text-white-50 mb-1">
                                            Неограничен интернет за до 5 устройства.
                                        </p>
                                        <div class="small text-info">
                                            + €6 / ден
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="alert alert-info bg-opacity-10 border border-info border-opacity-25 text-info small mt-4 mb-0">
                            <i class="fa-solid fa-circle-info me-1"></i>
                            Наличието на допълнителни услуги зависи от партньора и ще бъде потвърдено в договора за наем.
                        </div>
                    </div>
                    <!-- 4. ЗАСТРАХОВКИ -->
                    <div class="tv-card-panel mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div>
                                <h2 class="tv-section-title mb-1">4. Застрахователни пакети</h2>
                                <p class="tv-filter-sub mb-0">
                                    Изберете нивото на защита за щети, кражба и стъкла/гуми.
                                </p>
                            </div>
                            <a class="tv-filter-link-more" asp-controller="Cars" asp-action="Policies">
                                Виж политики <i class="fa-solid fa-arrow-right ms-1"></i>
                            </a>
                        </div>
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="tv-insurance-option">
                                    <div class="form-check">
                                        <input checked="" class="form-check-input" id="insBasic" name="insPackage" type="radio" />
                                        <div class="tv-insurance-shell">
                                            <div class="tv-insurance-header">
                                                <div>
                                                    <div class="tv-insurance-title">Базова защита</div>
                                                    <div class="tv-insurance-sub">CDW + TP · Франчайз €800</div>
                                                </div>
                                                <div class="tv-insurance-price">
                                                    Включено в цената
                                                </div>
                                            </div>
                                            <ul class="tv-list-info small mb-0">
                                                <li><i class="fa-solid fa-check text-success me-1"></i> Покрива щети при ПТП</li>
                                                <li><i class="fa-solid fa-check text-success me-1"></i> Покрива кражба на автомобила</li>
                                                <li><i class="fa-solid fa-xmark text-danger me-1"></i> Не покрива стъкла, гуми, джанти</li>
                                            </ul>
                                        </div>
                                    </div>
                                </label>
                            </div>
                            <div class="col-12">
                                <label class="tv-insurance-option">
                                    <div class="form-check">
                                        <input class="form-check-input" id="insStandard" name="insPackage" type="radio" />
                                        <div class="tv-insurance-shell">
                                            <div class="tv-insurance-header">
                                                <div>
                                                    <div class="tv-insurance-title">Разширена защита</div>
                                                    <div class="tv-insurance-sub">CDW + SCDW · Франчайз €300</div>
                                                </div>
                                                <div class="tv-insurance-price">
                                                    + €10 / ден
                                                </div>
                                            </div>
                                            <ul class="tv-list-info small mb-0">
                                                <li><i class="fa-solid fa-check text-success me-1"></i> Намален франчайз до €300</li>
                                                <li><i class="fa-solid fa-check text-success me-1"></i> Частично покритие за гуми/стъкла</li>
                                            </ul>
                                        </div>
                                    </div>
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="tv-card-panel mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div>
                                <h2 class="tv-section-title mb-1">5. Данни на шофьора</h2>
                                <p class="tv-filter-sub mb-0">Въведете данните точно по документи.</p>
                            </div>
                        </div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="small text-secondary fw-bold ms-2 mb-1">Име и Фамилия (Латиница)</label>
                                <div class="tv-input-wrapper">
                                    <i class="fa-regular fa-user tv-input-icon"></i>
                                    <input class="tv-input" type="text" placeholder="IVAN PETROV" required />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="small text-secondary fw-bold ms-2 mb-1">Телефон за връзка</label>
                                <div class="tv-input-wrapper">
                                    <i class="fa-solid fa-phone tv-input-icon"></i>
                                    <input class="tv-input" type="tel" placeholder="+359..." required />
                                </div>
                            </div>
                            <div class="col-12">
                                <label class="small text-secondary fw-bold ms-2 mb-1">Номер на шофьорска книжка</label>
                                <div class="tv-input-wrapper">
                                    <i class="fa-solid fa-id-card tv-input-icon"></i>
                                    <input class="tv-input" type="text" placeholder="СУМПС №" required />
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 mb-5">
                        <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill fw-bold py-3 shadow-lg"
                                style="background: linear-gradient(135deg, #0ea5e9 0%, #2563eb 100%); border: none;">
                            <i class="fa-solid fa-check-double me-2"></i> ЗАВЪРШИ РЕЗЕРВАЦИЯТА
                        </button>
                    </div>

                </div>
            </div>
        </section>
    </div>
    @section Scripts {
        <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
        <script>
            $(document).ready(function () {
            // 1. Функция за ръчно кликане (прави бутона оранжев/син и маха стария активен в същата група)
            $('.tv-chip-toggle').on('click', function () {
            var parentGroup = $(this).parent();
            parentGroup.find('.tv-chip-toggle').removeClass('active tv-chip-active');
            $(this).addClass('active tv-chip-active');

            // Ако кликнеш на локация, попълни и input полето
            if ($(this).closest('.col-12').find('#pickupLoc').length > 0) {
            $('#pickupLoc').val($(this).text().trim());
            }
            });

            // 2. Скриптът, който вече имаш за прехвърляне на данни от Grid към Booking
            $(document).on('click', '.car-item .btn-view, .car-item a:contains("Виж")', function (e) {
            e.preventDefault();
            var carItem = $(this).closest('.car-item');
            var originalHref = $(this).attr('href');
            var carTitle = carItem.find('.tv-hotel-grid-title').text().toLowerCase();
            var carDescription = carItem.text().toLowerCase();

            var isAuto = carDescription.includes("автоматик") || carTitle.includes("tiguan");
            var isSUV = carDescription.includes("suv") || carDescription.includes("джип") || carTitle.includes("tiguan");
            var isHybrid = carDescription.includes("хибрид");

            var url = new URL(window.location.origin + originalHref);
            url.searchParams.set('p_auto', isAuto);
            url.searchParams.set('p_class', isSUV ? 'suv' : 'sedan');
            url.searchParams.set('p_hybrid', isHybrid);

            window.location.href = url.toString();
            });
            });
        </script>
    }
</main>