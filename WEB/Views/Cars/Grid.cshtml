@{
    ViewData["Title"] = "Коли под наем – Travelis";
}
@{
    string loc = ViewBag.SelectedLocation as string ?? "София";
    string airport = "SOF";
    if (loc.Contains("Варна")) airport = "VAR";
    if (loc.Contains("Бургас")) airport = "BOJ";
    if (loc.Contains("Банско")) airport = "4x4"; // Примерно
}

<main class="tv-main-hotels">
    <div class="container">
        <!-- HERO SECTION -->
        <section class="tv-hero-section pt-0 pb-5">
            <div class="tv-hotels-hero">
                <div class="tv-hotels-hero-inner row align-items-center g-4">
                    <div class="col-lg-7">
                        <span class="tv-hotels-hero-badge mb-2">
                            <i class="fa-solid fa-location-arrow me-1"></i>
                            @ViewBag.SelectedLocation · @ViewBag.DateRange
                        </span>
                        <h1 class="tv-hotels-hero-title mb-2">Коли под наем</h1>
                        <p class="tv-hotels-hero-sub mb-0">19 автомобила налични за твоите дати.</p>
                    </div>
                    <div class="col-lg-5 text-lg-end">
                        <div class="d-inline-flex gap-2">
                            <a asp-controller="Cars" asp-action="Index" class="tv-btn-primary text-decoration-none">
                                <i class="fa-solid fa-pen-to-square me-2"></i> Промени
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
        <!-- MAIN LAYOUT -->
        <div class="row g-4">
            <!-- LEFT: FILTERS SIDEBAR -->
            <aside class="col-12 col-xl-4 col-xxl-3">
                <!-- Mobile Trigger -->
           

                <!-- Desktop Panel -->
                <div class="d-none d-xl-block tv-filter-shell sticky-xl-top" style="top: 100px;">
                    <div class="tv-filter-panel">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <div class="tv-filter-title-main">Филтри</div>
                                <div class="tv-filter-sub">Клас, гориво и екстри.</div>
                            </div>
                            <a href="javascript:void(0);" id="resetFilters" class="btn btn-link p-0 tv-filter-sub text-decoration-none small">
                                Изчисти
                            </a>
                        </div>
                        <!-- Class -->
                        <div class="tv-filter-section">
                            <div class="tv-filter-label">Клас автомобил</div>
   
                            <label class="tv-check-custom">
                                <input class="tv-check-input" type="checkbox" value="hatchback" />
                                <span class="tv-check-label-inner d-flex align-items-center gap-2">
                                    <span class="tv-check-box"><i class="fa-solid fa-check text-dark" style="font-size: 0.7rem;"></i></span>
                                    <span class="tv-check-text">Хечбек</span>
                                </span>
                            </label>

                            <label class="tv-check-custom">
                                <input class="tv-check-input" type="checkbox" value="sedan" />
                                <span class="tv-check-label-inner d-flex align-items-center gap-2">
                                    <span class="tv-check-box"><i class="fa-solid fa-check text-dark" style="font-size: 0.7rem;"></i></span>
                                    <span class="tv-check-text">Седан</span>
                                </span>
                            </label>

                            <label class="tv-check-custom">
                                <input class="tv-check-input" type="checkbox" value="suv" />
                                <span class="tv-check-label-inner d-flex align-items-center gap-2">
                                    <span class="tv-check-box"><i class="fa-solid fa-check text-dark" style="font-size: 0.7rem;"></i></span>
                                    <span class="tv-check-text">SUV </span>
                                </span>
                            </label>

                            <label class="tv-check-custom">
                                <input class="tv-check-input" type="checkbox" value="van" />
                                <span class="tv-check-label-inner d-flex align-items-center gap-2">
                                    <span class="tv-check-box"><i class="fa-solid fa-check text-dark" style="font-size: 0.7rem;"></i></span>
                                    <span class="tv-check-text">Ван</span>
                                </span>
                            </label>
                        </div>
                        <!-- Price -->
                        <div class="tv-filter-section">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <div class="tv-filter-label mb-0">Цена за ден</div>
                                <span id="priceRangeText" class="tv-filter-range-value">€20 - €500</span>
                            </div>
                            <input id="priceRangeInput" class="form-range tv-input-range" max="500" min="20" step="10" type="range" value="500" />
                        </div>
                        <!-- Specs -->
                        <div class="d-flex flex-wrap gap-2">
                            <button type="button" class="tv-chip-toggle spec-chip">
                                <i class="fa-solid fa-gear me-1"></i> Автоматик
                            </button>
                            <button type="button" class="tv-chip-toggle spec-chip">
                                <i class="fa-solid fa-hand-pointer me-1"></i> Ръчна
                            </button>

                            <button type="button" class="tv-chip-toggle spec-chip">
                                <i class="fa-solid fa-snowflake me-1"></i> Климатик
                            </button>

                            <button type="button" class="tv-chip-toggle spec-chip">
                                <i class="fa-solid fa-gas-pump me-1"></i> Дизел
                            </button>
                            <button type="button" class="tv-chip-toggle spec-chip">
                                <i class="fa-solid fa-leaf me-1"></i> Хибрид / Електрически
                            </button>
                            
                        </div>
                        <!-- Seats -->
                    <div class="tv-filter-section mt-3">
                        <div class="tv-filter-label mb-2">БРОЙ МЕСТА</div>
                        <div class="d-flex gap-2">
                            <button type="button" class="tv-chip-toggle seat-chip">2+</button>
                            <button type="button" class="tv-chip-toggle seat-chip">4-5</button>
                            <button type="button" class="tv-chip-toggle seat-chip">7+</button>
                        </div>
                    </div>
                        <!-- Actions -->
                        <div class="tv-filter-section pt-3">
                            <button class="tv-btn-primary w-100 py-2">Приложи филтри</button>
                        </div>
                    </div>
                </div>
                <!-- Offcanvas Mobile -->
                <div class="offcanvas offcanvas-end tv-offcanvas-filters d-xl-none" id="tvFiltersOffcanvas" tabindex="-1">
                    <div class="offcanvas-header">
                        <h5 class="offcanvas-title text-white">Филтри</h5>
                        <button class="btn-close btn-close-white" data-bs-dismiss="offcanvas" type="button"></button>
                    </div>
                    <div class="offcanvas-body">
                        <!-- Same content for mobile -->
                        <div class="tv-filter-panel">
                            <p class="text-white-50">Mobile filters placeholder.</p>
                        </div>
                    </div>
                </div>

        </aside>
    
            <!-- RIGHT: GRID -->
            <div class="col-12 col-xl-8 col-xxl-9">
