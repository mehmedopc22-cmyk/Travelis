                <!-- PAGINATION -->
                <div class="tv-pagination-wrapper mt-auto pt-5" id="pagination-container">
                    <nav aria-label="Пагинация" class="tv-pagination d-flex justify-content-center">
        
                        @{
                            // Превръщаме текущата страница в число (int), за да можем да смятаме с него
                            var pageQuery = Context.Request.Query["page"].ToString();
                            int currentPage = string.IsNullOrEmpty(pageQuery) ? 1 : int.Parse(pageQuery);
            
                            // Определяме предишна и следваща страница
                            int prevPage = currentPage > 1 ? currentPage - 1 : 1;
                            int nextPage = currentPage < 3 ? currentPage + 1 : 3; // Тук 3 е максималният брой страници
                        }

                        <a class="tv-page-link @(currentPage == 1 ? "disabled" : "")"
                               asp-controller="Cars" asp-action="Grid"
                               asp-route-page="@prevPage"
                               asp-route-location="@Context.Request.Query["location"]"
                               asp-route-startDate="@Context.Request.Query["startDate"]"
                               asp-route-endDate="@Context.Request.Query["endDate"]">
                            <i class="fa-solid fa-angle-left"></i>
                        </a>

                        <a class="tv-page-link @(currentPage == 1 ? "active" : "")"
                           asp-controller="Cars" asp-action="Grid"
                           asp-route-page="1"
                           asp-route-location="@Context.Request.Query["location"]"
                           asp-route-startDate="@Context.Request.Query["startDate"]"
                           asp-route-endDate="@Context.Request.Query["endDate"]">1</a>

                        <a class="tv-page-link @(currentPage == 2 ? "active" : "")"
                           asp-controller="Cars" asp-action="Grid"
                           asp-route-page="2"
                           asp-route-location="@Context.Request.Query["location"]"
                           asp-route-startDate="@Context.Request.Query["startDate"]"
                           asp-route-endDate="@Context.Request.Query["endDate"]">2</a>

                        <a class="tv-page-link @(currentPage == 3 ? "active" : "")"
                           asp-controller="Cars" asp-action="Grid"
                           asp-route-page="3"
                           asp-route-location="@Context.Request.Query["location"]"
                           asp-route-startDate="@Context.Request.Query["startDate"]"
                           asp-route-endDate="@Context.Request.Query["endDate"]">3</a>

                        <span class="tv-page-link disabled">...</span>

                        <a class="tv-page-link @(currentPage == 3 ? "disabled" : "")"
                               asp-controller="Cars" asp-action="Grid"
                               asp-route-page="@nextPage"
                               asp-route-location="@Context.Request.Query["location"]"
                               asp-route-startDate="@Context.Request.Query["startDate"]"
                               asp-route-endDate="@Context.Request.Query["endDate"]">
                            <i class="fa-solid fa-angle-right"></i>
                        </a>
                    </nav>
                </div>
               </div> </div> </div> 
               @section Scripts {
                    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
                    <script>
                        $(document).ready(function () {
                        console.log("Системата е готова и изгледите са фиксирани!");
                        $(document).on('click', '.car-item .btn-view, .car-item a:contains("Виж")', function (e) {
                        e.preventDefault();
    
                        var carItem = $(this).closest('.car-item');
                        var originalHref = $(this).attr('href'); // Вече съдържа локация и дати

                        // Взимаме данните от атрибутите на колата
                        var isAuto = carItem.attr('data-transmission') === 'automatic';
                        var carClass = carItem.attr('data-class');
                        var fuel = carItem.attr('data-fuel');
                        var isHybrid = (fuel === 'hybrid' || fuel === 'hybrid-electric');

                        // Сглобяваме линка правилно
                        // Ако в оригиналния линк вече има '?', добавяме с '&', ако няма - с '?'
                        var separator = originalHref.indexOf('?') !== -1 ? "&" : "?";
    
                        var finalUrl = originalHref + separator +
                        "p_auto=" + isAuto +
                        "&p_class=" + carClass +
                        "&p_hybrid=" + isHybrid;

                        console.log("Отивам на: " + finalUrl);
                        window.location.href = finalUrl;
                        });

                        // --- ИНИЦИАЛИЗАЦИЯ (ОТ URL ПАРАМЕТРИ) ---
                        $('.tv-check-input').prop('checked', false);
                        $('.spec-chip, .seat-chip').removeClass('tv-chip-active');

                        const urlParams = new URLSearchParams(window.location.search);

                        if (urlParams.get('priorityHybrid') === 'true') {
                        $('.spec-chip:contains("Хибрид")').addClass('tv-chip-active');
                        }
                        if (urlParams.get('priorityAuto') === 'true') {
                        $('.spec-chip:contains("Автоматик")').addClass('tv-chip-active');
                        }
                        if (urlParams.get('prioritySeats') === 'true') {
                        $('.seat-chip:contains("7+")').addClass('tv-chip-active');
                        }

                        applyFilters();
                        $('#sortOrder').trigger('change');

                        // --- СЪБИТИЯ (EVENTS) ---

                        $(document).on('input', '#priceRangeInput', function() {
                        var val = $(this).val();
                        $('#priceRangeText').text('€20 - €' + val);
                        applyFilters();
                        });

                        $(document).on('click', '.seat-chip', function () {
                        if ($(this).hasClass('tv-chip-active')) {
                        $(this).removeClass('tv-chip-active');
                        } else {
                        $('.seat-chip').removeClass('tv-chip-active');
                        $(this).addClass('tv-chip-active');
                        }
                        applyFilters();
                        });

                        $(document).on('click', '.spec-chip', function () {
                        $(this).toggleClass('tv-chip-active');
                        applyFilters();
                        });

                        $(document).on('click', '#btnList', function() {
                        $('#btnGrid').removeClass('active');
                        $(this).addClass('active');
                        $('#carsContainer').addClass('list-view');
                        $('.car-item').attr('class', 'col-12 list-view-item car-item');
                        });

                        $(document).on('click', '#btnGrid', function() {
                        $('#btnList').removeClass('active');
                        $(this).addClass('active');
                        $('#carsContainer').removeClass('list-view');
                        $('.car-item').attr('class', 'col-md-6 col-xl-4 car-item');
                        });

                        $(document).on('change', '#sortOrder', function() {
                        var selection = $(this).val();
                        var items = $('.car-item').get();

                        items.sort(function(a, b) {
                        var priceA = parseFloat($(a).attr('data-price')) || 0;
                        var priceB = parseFloat($(b).attr('data-price')) || 0;
                        var recA = parseInt($(a).attr('data-recommended')) || 0;
                        var recB = parseInt($(b).attr('data-recommended')) || 0;

                        if (selection === 'price-low') return priceA - priceB;
                        if (selection === 'price-high') return priceB - priceA;
                        return recB - recA;
                        });

                        var container = $('#carsContainer');
                        $.each(items, function(i, li) {
                        container.append(li);
                        });

                        applyFilters();
                        });

                        function applyFilters() {
                        var selectedClasses = [];
                        $('.tv-check-input:checked').each(function() {
                        selectedClasses.push($(this).val());
                        });

                        var selectedFuels = [];
                        var selectedTransmissions = [];
                        $('.spec-chip.tv-chip-active').each(function() {
                        var text = $(this).text().toLowerCase().trim();
                        if (text.includes('дизел')) selectedFuels.push('diesel');
                        if (text.includes('хибрид') || text.includes('електри')) selectedFuels.push('hybrid-electric');
                        if (text.includes('автоматик')) selectedTransmissions.push('automatic');
                        if (text.includes('ръчна')) selectedTransmissions.push('manual');
                        });

                        var maxPrice = parseFloat($('#priceRangeInput').val());
                        var seatsText = $('.seat-chip.tv-chip-active').text().trim();
                        var visibleCount = 0;

                        $('.car-item').each(function () {
                        var item = $(this);
                        var show = true;

                        if (parseFloat(item.attr('data-price')) > maxPrice) show = false;
                        if (selectedClasses.length > 0 && !selectedClasses.includes(item.attr('data-class'))) show = false;
                        if (selectedFuels.length > 0 && !selectedFuels.includes(item.attr('data-fuel'))) show = false;
                        if (selectedTransmissions.length > 0 && !selectedTransmissions.includes(item.attr('data-transmission'))) show = false;

                        if (seatsText !== "") {
                        var carSeats = parseInt(item.attr('data-seats'));
                        if (seatsText.includes('4-5') && (carSeats < 4 || carSeats > 5)) show = false;
                        if (seatsText.includes('7+') && carSeats < 7) show = false;
                        if (seatsText.includes('2+') && carSeats < 2) show = false;
                        }

                        if (show) {
                        item.removeClass('d-none');
                        visibleCount++;
                        } else {
                        item.addClass('d-none');
                        }
                        });

                        if (visibleCount > 0) $('#pagination-container').show();
                        else $('#pagination-container').hide();
                        }

                        $(document).on('click', '.tv-btn-primary:contains("Приложи"), #applyFiltersBtn', function (e) {
                        e.preventDefault();
                        applyFilters();
                        });

                        $(document).on('click', '#resetFilters', function (e) {
                        e.preventDefault();
                        $('.tv-check-input').prop('checked', false);
                        $('.spec-chip, .seat-chip').removeClass('tv-chip-active');
                        var maxVal = $('#priceRangeInput').attr('max') || 500;
                        $('#priceRangeInput').val(maxVal);
                        $('#priceRangeText').text('€20 - €' + maxVal);
                        applyFilters();
                        });

                        $(document).on('click', '.car-item .btn-view, .car-item a:contains("Виж")', function (e) {
                        e.preventDefault();
    
                        var carItem = $(this).closest('.car-item');
                        var originalHref = $(this).attr('href');
    
                        // Взимаме заглавието на колата (напр. "VW Tiguan")
                        var carTitle = carItem.find('.tv-hotel-grid-title').text().toLowerCase();
                        var carDescription = carItem.text().toLowerCase();
    
                        // Логика за Tiguan (SUV, Automatic)
                        var isAuto = carDescription.includes("автоматик") || carTitle.includes("tiguan");
                        var isSUV = carDescription.includes("suv") || carDescription.includes("джип") || carTitle.includes("tiguan");
                        var isHybrid = carDescription.includes("хибрид");

                        // Сглобяваме URL
                        var url = new URL(window.location.origin + originalHref);
                        url.searchParams.set('p_auto', isAuto);
                        url.searchParams.set('p_class', isSUV ? 'suv' : 'sedan');
                        url.searchParams.set('p_hybrid', isHybrid);

                        window.location.href = url.toString();
                        });
                        });
                      
                    </script>
    
           
        
    }
    

</main>