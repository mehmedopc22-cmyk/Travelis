@{
    ViewData["Title"] = "Коли под наем – Travelis";
}

<main class="tv-main-hotels">
    <div class="container">
        <!-- HERO SECTION -->
        <section class="tv-hero-section pt-0 pb-5">
            <div class="tv-hotels-hero">
                <div class="tv-hotels-hero-inner row align-items-center g-4">
                    <div class="col-lg-7">
                        <span class="tv-hotels-hero-badge mb-2">
                            <i class="fa-solid fa-location-arrow"></i> София (SOF) · 12-15 Дек
                        </span>
                        <h1 class="tv-hotels-hero-title mb-2">Коли под наем</h1>
                        <p class="tv-hotels-hero-sub mb-0">19 автомобила налични за твоите дати.</p>
                    </div>
                    <div class="col-lg-5 text-lg-end">
                        <div class="d-inline-flex gap-2">
                            <a asp-controller="Cars" asp-action="Index" class="tv-btn-primary text-decoration-none">
                                <i class="fa-solid fa-pen-to-square me-2"></i> Промени
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
        <!-- MAIN LAYOUT -->
        <div class="row g-4 g-xl-5 align-items-start">
            <!-- LEFT: FILTERS SIDEBAR -->
            <aside class="col-12 col-xl-4 col-xxl-3">
                <!-- Mobile Trigger -->
                <div class="d-flex d-xl-none justify-content-between align-items-center mb-3">
                    <button class="tv-mobile-filter-btn" data-bs-target="#tvFiltersOffcanvas" data-bs-toggle="offcanvas" type="button">
                        <i class="fa-solid fa-sliders"></i> Филтри
                    </button>
                    <span class="tv-results-count small">19 автомобила</span>
                </div>
                <!-- Desktop Panel -->
                <div class="d-none d-xl-block tv-filter-shell sticky-xl-top" style="top: 100px;">
                    <div class="tv-filter-panel">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <div class="tv-filter-title-main">Филтри</div>
                                <div class="tv-filter-sub">Клас, гориво и екстри.</div>
                            </div>
                            <a asp-controller="Cars" asp-action="Grid" class="btn btn-link p-0 tv-filter-sub text-decoration-none small">
                                Изчисти
                            </a>
                        </div>
                        <!-- Class -->
                        <div class="tv-filter-section">
                            <div class="tv-filter-label">Клас автомобил</div>
                            <label class="tv-check-custom">
                                <input checked="" class="tv-check-input" type="checkbox" />
                                <div class="tv-check-label-inner d-flex align-items-center gap-2">
                                    <span class="tv-check-box"><i class="fa-solid fa-check text-dark" style="font-size: 0.7rem;"></i></span>
                                    <span class="tv-check-text">Икономичен (4)</span>
                                </div>
                            </label>
                            <label class="tv-check-custom">
                                <input class="tv-check-input" type="checkbox" />
                                <div class="tv-check-label-inner d-flex align-items-center gap-2">
                                    <span class="tv-check-box"><i class="fa-solid fa-check text-dark" style="font-size: 0.7rem;"></i></span>
                                    <span class="tv-check-text">Седан / Среден (8)</span>
                                </div>
                            </label>
                            <label class="tv-check-custom">
                                <input class="tv-check-input" type="checkbox" />
                                <div class="tv-check-label-inner d-flex align-items-center gap-2">
                                    <span class="tv-check-box"><i class="fa-solid fa-check text-dark" style="font-size: 0.7rem;"></i></span>
                                    <span class="tv-check-text">SUV / Джип (5)</span>
                                </div>
                            </label>
                            <label class="tv-check-custom">
                                <input class="tv-check-input" type="checkbox" />
                                <div class="tv-check-label-inner d-flex align-items-center gap-2">
                                    <span class="tv-check-box"><i class="fa-solid fa-check text-dark" style="font-size: 0.7rem;"></i></span>
                                    <span class="tv-check-text">Лукс / Премиум (2)</span>
                                </div>
                            </label>
                        </div>
                        <!-- Price -->
                        <div class="tv-filter-section">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <div class="tv-filter-label mb-0">Цена за ден</div>
                                <span id="priceRangeText" class="tv-filter-range-value">€20 - €500</span>
                            </div>
                            <input id="priceRangeInput" class="form-range tv-input-range" max="500" min="20" step="10" type="range" value="500" />
                        </div>
                        <!-- Specs -->
                        <div class="d-flex flex-wrap gap-2">
                            <button type="button" class="tv-chip-toggle spec-chip">
                                <i class="fa-solid fa-gear me-1"></i> Автоматик
                            </button>
                            <button type="button" class="tv-chip-toggle spec-chip">
                                <i class="fa-solid fa-snowflake me-1"></i> Климатик
                            </button>
                            <button type="button" class="tv-chip-toggle spec-chip">
                                <i class="fa-solid fa-gas-pump me-1"></i> Дизел
                            </button>
                            <button type="button" class="tv-chip-toggle spec-chip">
                                <i class="fa-solid fa-leaf me-1"></i> Хибрид
                            </button>
                            <button type="button" class="tv-chip-toggle spec-chip">
                                <i class="fa-solid fa-bolt me-1"></i> Електрически
                            </button>
                        </div>
                        </div>
                        <!-- Seats -->
                        <div class="tv-filter-section">
                            <div class="tv-filter-label">Брой места</div>
                            <div class="d-flex gap-2">
                                <button type="button" class="tv-filter-pill seat-chip">2+</button>
                                <button type="button" class="tv-filter-pill seat-chip tv-chip-active">4-5</button>
                                <button type="button" class="tv-filter-pill seat-chip">7+</button>
                            </div>
                        </div>
                        <!-- Actions -->
                        <div class="tv-filter-section pt-3">
                            <button class="tv-btn-primary w-100 py-2">Приложи филтри</button>
                        </div>
                    </div>
                </div>
                <!-- Offcanvas Mobile -->
                <div class="offcanvas offcanvas-end tv-offcanvas-filters d-xl-none" id="tvFiltersOffcanvas" tabindex="-1">
                    <div class="offcanvas-header">
                        <h5 class="offcanvas-title text-white">Филтри</h5>
                        <button class="btn-close btn-close-white" data-bs-dismiss="offcanvas" type="button"></button>
                    </div>
                    <div class="offcanvas-body">
                        <!-- Same content for mobile -->
                        <div class="tv-filter-panel">
                            <p class="text-white-50">Mobile filters placeholder.</p>
                        </div>
                    </div>
                </div>
            </aside>
            <!-- RIGHT: GRID -->
            <div class="col-12 col-xl-8 col-xxl-9">
                <!-- Toolbar -->
                <div class="tv-grid-toolbar">
                    <div class="d-flex align-items-center gap-3">
                        <div class="tv-view-switcher">
                            <a class="tv-view-btn" asp-controller="Cars" asp-action="Grid"><i class="fa-solid fa-list"></i></a>
                            <button class="tv-view-btn active"><i class="fa-solid fa-border-all"></i></button>
                        </div>
                        <span class="text-white-50 small">Показани 1-6 от 19</span>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <label class="text-white-50 small me-1">Сортирай:</label>
                        <select class="form-select form-select-sm bg-dark text-white border-secondary" style="width: auto; border-radius: 20px;">
                            <option>Препоръчани</option>
                            <option>Цена (Ниска)</option>
                            <option>Рейтинг</option>
                        </select>
                    </div>
                </div>
                <div class="row g-4">
                    <!-- Card 1: Economy -->
                    <div class="col-md-6 col-xl-4">
                        <article class="tv-hotel-grid-card">
                            <div class="tv-hotel-grid-media">
                                <img alt="Toyota Yaris" class="tv-hotel-grid-img" src="https://scene7.toyota.eu/is/image/toyotaeurope/YAR0003_24_WEB:Large-Landscape?ts=1722500144555&amp;resMode=sharp2&amp;op_usm=1.75,0.3,2,0&amp;fmt=png-alpha" />
                                <span class="tv-grid-badge-top">Top Deal</span>
                                <button class="tv-grid-fav-btn"><i class="fa-regular fa-heart"></i></button>
                                <div class="tv-grid-location-badge">
                                    <i class="fa-solid fa-leaf text-success"></i>
                                    Еко
                                </div>
                            </div>
                            <div class="tv-hotel-grid-body">
                                <div class="tv-hotel-grid-header">
                                    <h3 class="tv-hotel-grid-title">Toyota Yaris</h3>
                                    <div class="tv-hotel-grid-rating">4.8 <i class="fa-solid fa-star"></i></div>
                                </div>
                                <div class="tv-grid-amenities">
                                    <span class="tv-spec-item"><i class="fa-solid fa-user"></i> 4</span>
                                    <span class="tv-spec-item"><i class="fa-solid fa-suitcase"></i> 1</span>
                                    <span class="tv-spec-item"><i class="fa-solid fa-gear"></i> Ръчна</span>
                                    <span class="tv-spec-item"><i class="fa-solid fa-gas-pump"></i> Бензин</span>
                                </div>
                                <p class="small text-white-50 mb-0 flex-grow-1">
                                    Компактен и икономичен, идеален за
                                    града.
                                </p>
                                <div class="tv-hotel-grid-footer">
                                    <div>
                                        <span class="tv-grid-price-label">Цена за ден</span>
                                        <span class="tv-grid-price-val">€35</span>
                                    </div>
                                    <a class="tv-btn-grid-action" asp-controller="Cars" asp-action="Details">Виж <i class="fa-solid fa-arrow-right"></i></a>
                                </div>
                            </div>
                        </article>
                    </div>
                    <!-- Card 2: Sedan -->
                    <div class="col-md-6 col-xl-4">
                        <article class="tv-hotel-grid-card">
                            <div class="tv-hotel-grid-media">
                                <img alt="Toyota Camry" class="tv-hotel-grid-img" src="https://di-uploads-pod7.dealerinspire.com/toyotachulavista/uploads/2023/09/2024-Toyota-Camry-Hybrid.png" />
                                <span class="tv-grid-badge-top" style="background: linear-gradient(135deg, #0ea5e9, #2563eb);">
                                    Travelis
                                    Choice
                                </span>
                                <button class="tv-grid-fav-btn"><i class="fa-regular fa-heart"></i></button>
                                <div class="tv-grid-location-badge">
                                    <i class="fa-solid fa-bolt text-warning"></i>
                                    Instant
                                </div>
                            </div>
                            <div class="tv-hotel-grid-body">
                                <div class="tv-hotel-grid-header">
                                    <h3 class="tv-hotel-grid-title">Toyota Camry Hybrid</h3>
                                    <div class="tv-hotel-grid-rating">4.9 <i class="fa-solid fa-star"></i></div>
                                </div>
                                <div class="tv-grid-amenities">
                                    <span class="tv-spec-item"><i class="fa-solid fa-user"></i> 5</span>
                                    <span class="tv-spec-item"><i class="fa-solid fa-suitcase"></i> 2</span>
                                    <span class="tv-spec-item"><i class="fa-solid fa-gear"></i> Авто</span>
                                    <span class="tv-spec-item"><i class="fa-solid fa-leaf"></i> Хибрид</span>
                                </div>
                                <p class="small text-white-50 mb-0 flex-grow-1">
                                    Комфортен бизнес седан с нисък
                                    разход.
                                </p>
                                <div class="tv-hotel-grid-footer">
                                    <div>
                                        <span class="tv-grid-price-label">Цена за ден</span>
                                        <span class="tv-grid-price-val text-info">€70</span>
                                    </div>
                                    <a class="tv-btn-grid-action" asp-controller="Cars" asp-action="Details">Виж <i class="fa-solid fa-arrow-right"></i></a>
                                </div>
                            </div>
                        </article>
                    </div>
                    <!-- Card 3: SUV -->
                    <div class="col-md-6 col-xl-4">
                        <article class="tv-hotel-grid-card">
                            <div class="tv-hotel-grid-media">
                                <img alt="VW Tiguan" class="tv-hotel-grid-img" src="https://7cars.bg/wp-content/uploads/2024/05/1-18.jpg" />
                                <button class="tv-grid-fav-btn"><i class="fa-regular fa-heart"></i></button>
                                <div class="tv-grid-location-badge"><i class="fa-solid fa-mountain"></i> 4x4</div>
                            </div>
                            <div class="tv-hotel-grid-body">
                                <div class="tv-hotel-grid-header">
                                    <h3 class="tv-hotel-grid-title">VW Tiguan</h3>
                                    <div class="tv-hotel-grid-rating">4.7 <i class="fa-solid fa-star"></i></div>
                                </div>
                                <div class="tv-grid-amenities">
                                    <span class="tv-spec-item"><i class="fa-solid fa-user"></i> 5</span>
                                    <span class="tv-spec-item"><i class="fa-solid fa-suitcase"></i> 3</span>
                                    <span class="tv-spec-item"><i class="fa-solid fa-gear"></i> Авто</span>
                                    <span class="tv-spec-item"><i class="fa-solid fa-gas-pump"></i> Дизел</span>
                                </div>
                                <p class="small text-white-50 mb-0 flex-grow-1">
                                    Просторен SUV, подходящ за планина.
                                </p>
                                <div class="tv-hotel-grid-footer">
                                    <div>
                                        <span class="tv-grid-price-label">Цена за ден</span>
                                        <span class="tv-grid-price-val">€85</span>
                                    </div>
                                    <a class="tv-btn-grid-action" asp-controller="Cars" asp-action="Details">Виж <i class="fa-solid fa-arrow-right"></i></a>
                                </div>
                            </div>
                        </article>
                    </div>
                    <!-- Card 4: Van -->
                    <div class="col-md-6 col-xl-4">
                        <article class="tv-hotel-grid-card">
                            <div class="tv-hotel-grid-media">
                                <img alt="Mercedes V-Class" class="tv-hotel-grid-img" src="https://www.novakola.bg/wp-content/uploads/2024/05/1032931705584485dsc02773-1050x700-768x512.jpg" />
                                <span class="tv-grid-badge-top" style="background: #6366f1;">Premium</span>
                                <button class="tv-grid-fav-btn"><i class="fa-regular fa-heart"></i></button>
                            </div>
                            <div class="tv-hotel-grid-body">
                                <div class="tv-hotel-grid-header">
                                    <h3 class="tv-hotel-grid-title">Mercedes V-Class</h3>
                                    <div class="tv-hotel-grid-rating">5.0 <i class="fa-solid fa-star"></i></div>
                                </div>
                                <div class="tv-grid-amenities">
                                    <span class="tv-spec-item"><i class="fa-solid fa-user"></i> 7</span>
                                    <span class="tv-spec-item"><i class="fa-solid fa-suitcase"></i> 5</span>
                                    <span class="tv-spec-item"><i class="fa-solid fa-gear"></i> Авто</span>
                                    <span class="tv-spec-item"><i class="fa-solid fa-wifi"></i> WiFi</span>
                                </div>
                                <p class="small text-white-50 mb-0 flex-grow-1">
                                    Луксозен ван за групи и VIP
                                    трансфери.
                                </p>
                                <div class="tv-hotel-grid-footer">
                                    <div>
                                        <span class="tv-grid-price-label">Цена за ден</span>
                                        <span class="tv-grid-price-val">€150</span>
                                    </div>
                                    <a class="tv-btn-grid-action" asp-controller="Cars" asp-action="Details">Виж <i class="fa-solid fa-arrow-right"></i></a>
                                </div>
                            </div>
                        </article>
                    </div>
                    <!-- Card 5: Electric -->
                    <div class="col-md-6 col-xl-4">
                        <article class="tv-hotel-grid-card">
                            <div class="tv-hotel-grid-media">
                                <img alt="Tesla Model 3" class="tv-hotel-grid-img" src="https://upload.wikimedia.org/wikipedia/commons/thumb/9/91/2019_Tesla_Model_3_Performance_AWD_Front.jpg/1200px-2019_Tesla_Model_3_Performance_AWD_Front.jpg" />
                                <div class="tv-grid-location-badge"><i class="fa-solid fa-charging-station text-success"></i> EV</div>
                                <button class="tv-grid-fav-btn"><i class="fa-regular fa-heart"></i></button>
                            </div>
                            <div class="tv-hotel-grid-body">
                                <div class="tv-hotel-grid-header">
                                    <h3 class="tv-hotel-grid-title">Tesla Model 3</h3>
                                    <div class="tv-hotel-grid-rating">4.9 <i class="fa-solid fa-star"></i></div>
                                </div>
                                <div class="tv-grid-amenities">
                                    <span class="tv-spec-item"><i class="fa-solid fa-user"></i> 5</span>
                                    <span class="tv-spec-item"><i class="fa-solid fa-suitcase"></i> 2</span>
                                    <span class="tv-spec-item"><i class="fa-solid fa-gear"></i> Авто</span>
                                    <span class="tv-spec-item"><i class="fa-solid fa-bolt"></i> Ел.</span>
                                </div>
                                <p class="small text-white-50 mb-0 flex-grow-1">
                                    Модерно, тихо и екологично пътуване.
                                </p>
                                <div class="tv-hotel-grid-footer">
                                    <div>
                                        <span class="tv-grid-price-label">Цена за ден</span>
                                        <span class="tv-grid-price-val">€110</span>
                                    </div>
                                    <a class="tv-btn-grid-action" asp-controller="Cars" asp-action="Details">Виж <i class="fa-solid fa-arrow-right"></i></a>
                                </div>
                            </div>
                        </article>
                    </div>
                    <!-- Card 6: Convertible -->
                    <div class="col-md-6 col-xl-4">
                        <article class="tv-hotel-grid-card">
                            <div class="tv-hotel-grid-media">
                                <img alt="Convertible" class="tv-hotel-grid-img" src="https://www.topgear.com/sites/default/files/images/news-article/2020/09/773a5387e619ab48f7b768bcbed99f32/p90400385_highres.jpg" />
                                <span class="tv-grid-badge-top" style="background: #f59e0b;">Fun</span>
                                <button class="tv-grid-fav-btn"><i class="fa-regular fa-heart"></i></button>
                            </div>
                            <div class="tv-hotel-grid-body">
                                <div class="tv-hotel-grid-header">
                                    <h3 class="tv-hotel-grid-title">BMW 4 Series Cabrio</h3>
                                    <div class="tv-hotel-grid-rating">4.8 <i class="fa-solid fa-star"></i></div>
                                </div>
                                <div class="tv-grid-amenities">
                                    <span class="tv-spec-item"><i class="fa-solid fa-user"></i> 4</span>
                                    <span class="tv-spec-item"><i class="fa-solid fa-suitcase"></i> 1</span>
                                    <span class="tv-spec-item"><i class="fa-solid fa-gear"></i> Авто</span>
                                    <span class="tv-spec-item"><i class="fa-solid fa-wind"></i> Cabrio</span>
                                </div>
                                <p class="small text-white-50 mb-0 flex-grow-1">Наслади се на слънцето и пътя.</p>
                                <div class="tv-hotel-grid-footer">
                                    <div>
                                        <span class="tv-grid-price-label">Цена за ден</span>
                                        <span class="tv-grid-price-val">€130</span>
                                    </div>
                                    <a class="tv-btn-grid-action" asp-controller="Cars" asp-action="Details">Виж <i class="fa-solid fa-arrow-right"></i></a>
                                </div>
                            </div>
                        </article>
                    </div>
                </div>
                <!-- PAGINATION -->
                <nav aria-label="Пагинация" class="tv-pagination">
                    <a aria-label="Предишна" class="tv-page-link" asp-controller="Cars" asp-action="Grid">
                        <i class="fa-solid fa-angle-left"></i>
                    </a>
                    <a class="tv-page-link active" asp-controller="Cars" asp-action="Grid">1</a>
                    <a class="tv-page-link" asp-controller="Cars" asp-action="Grid">2</a>
                    <a class="tv-page-link" asp-controller="Cars" asp-action="Grid">3</a>
                    <span class="tv-page-link disabled">…</span>
                    <a aria-label="Следваща" class="tv-page-link" asp-controller="Cars" asp-action="Grid">
                        <i class="fa-solid fa-angle-right"></i>
                    </a>
                </nav>
            </div>
        </div>
    </div>

    @section Scripts {
        <script>
                $(document).ready(function () {
                    // 1. ЛОГИКА ЗА ЦЕНАТА
                    $('#priceRangeInput').on('input', function() {
                        var currentValue = $(this).val();
                        $('#priceRangeText').text('€20 - €' + currentValue);
                    });

                    // 2. ЛОГИКА ЗА БРОЙ МЕСТА (2+, 4-5, 7+)
                    // Тук използваме клас .seat-chip (добави го в HTML-а на бутоните за места)
                    $('.seat-chip').click(function () {
                        $('.seat-chip').removeClass('tv-chip-active');
                        $(this).addClass('tv-chip-active');
                    });

                    // 3. ЛОГИКА ЗА СПЕЦИФИКАЦИИ (Автоматик, Дизел и т.н.)
                    // Тук използваме клас .spec-chip (добави го в HTML-а на филтрите)
                    $('.spec-chip').click(function () {
                        $(this).toggleClass('tv-chip-active');
                    });
                                $('.spec-chip').click(function () {
                $(this).toggleClass('tv-chip-active');
            });
                });
        </script>
    }
</main>