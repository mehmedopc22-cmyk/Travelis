@using WEB.Models


@{
    
    ViewData["Title"] = "Наем на коли";
}

@section Styles {
   
    <link rel="stylesheet" href="~/css/style/assets_css_partners_cars_car-list_style_1.css" asp-append-version="true" />
}




<main class="tv-main-hotels">

  
    <div class="container">
        <!-- HERO: SEARCH + ORBS -->
        <section class="tv-hero-section py-5">
            <div class="row g-4 align-items-center">
                <div class="col-lg-7">
                    <div class="tv-hotels-hero position-relative overflow-hidden">
                        <!-- орбове / бекграунд -->
                        <div class="tv-orb tv-orb-sky"></div>
                        <div class="tv-orb tv-orb-indigo"></div>
                        <div class="tv-hotels-hero-inner">
                            <span class="tv-hotels-hero-badge mb-3">
                                <i class="fa-solid fa-location-arrow me-1"></i> София (SOF) · Днес 12:00 – 15 Дек 10:00
                            </span>
                            <h1 class="tv-hotels-hero-title mb-2">
                                Коли под наем в България
                            </h1>
                            <p class="tv-hotels-hero-sub mb-3">
                                Сравни оферти от водещи рент-а-кар компании – от икономични градски коли до луксозни SUV и ванове.
                            </p>
                            <div class="d-flex flex-wrap gap-2 mb-3">
                                <span class="tv-chip-pill">
                                    <i class="fa-solid fa-plane-departure me-1"></i> Вземане от летище
                                </span>
                                <span class="tv-chip-pill">
                                    <i class="fa-solid fa-bolt me-1"></i> Мигновено потвърждение
                                </span>
                                <span class="tv-chip-pill">
                                    <i class="fa-solid fa-shield-halved me-1"></i> Пълно каско опция
                                </span>
                            </div>
                            <div class="tv-ai-banner d-flex align-items-center gap-3 mt-3">
                                <div class="tv-ai-avatar">
                                    <i class="fa-solid fa-robot"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <div class="tv-ai-title">AI Rent-a-car асистент</div>
                                    <div class="tv-ai-sub">Попитай „Търся хибрид за 3 дни от летище Варна с включено каско“. </div>
                                </div>
                                <a class="tv-btn-outline-glass d-none d-md-inline-flex" href="../ai/ai-trip-builder.html">
                                    Стартирай <i class="fa-solid fa-arrow-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- HERO FORM -->
                <div class="col-lg-5">
                    <div class="tv-card-panel tv-search-panel">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div>
                                <div class="tv-filter-title-main">Намери идеалната кола</div>
                                <div class="tv-filter-sub">Локация, дати и възраст на шофьора.</div>
                            </div>
                            <span class="badge rounded-pill bg-success-subtle text-success-emphasis small">
                                <i class="fa-solid fa-check me-1"></i> Без скрити такси
                            </span>
                        </div>
                        <form class="row g-3">
                            <!-- Pickup location -->
                            <div class="col-12">
                                <label class="small text-secondary fw-bold ms-2 mb-1">
                                    Локация за вземане
                                </label>
                                <div class="tv-input-wrapper">
                                    <i class="fa-solid fa-location-dot tv-input-icon"></i>
                                    <input class="tv-input" placeholder="София летище (SOF)" type="text" />
                                </div>
                                <div class="d-flex flex-wrap gap-2 mt-2 small text-white-50">
                                    <button class="tv-chip-toggle location-chip tv-chip-active" type="button">
                                        София Център
                                    </button>
                                    <button class="tv-chip-toggle location-chip" type="button">
                                        SOF Терминал 2
                                    </button>
                                    <button class="tv-chip-toggle location-chip" type="button">
                                        Пловдив летище
                                    </button>
                                </div>
                            </div>
                            <!-- Pickup / Dropoff dates -->
                            <div class="col-md-6">
                                <label class="small text-secondary fw-bold ms-2 mb-1">Вземане</label>
                                <div class="tv-input-wrapper">
                                    <i class="fa-solid fa-calendar-day tv-input-icon"></i>
                                    <input class="tv-input" type="datetime-local" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="small text-secondary fw-bold ms-2 mb-1">Връщане</label>
                                <div class="tv-input-wrapper">
                                    <i class="fa-solid fa-calendar-check tv-input-icon"></i>
                                    <input class="tv-input" type="datetime-local" />
                                </div>
                            </div>
                            <!-- Different dropoff -->
                            <div class="col-12">
                                <div class="form-check form-switch d-flex align-items-center gap-2">
                                    <input class="form-check-input" id="diffDrop" type="checkbox" />
                                    <label class="form-check-label small text-white-50" for="diffDrop">
                                        Различна локация за връщане (напр. Варна вместо София)
                                    </label>
                                </div>
                            </div>
                            <!-- Driver age + residency -->
                            <div class="col-md-6">
                                <label class="small text-secondary fw-bold ms-2 mb-1">Възраст на шофьора</label>
                                <div class="tv-input-wrapper">
                                    <i class="fa-solid fa-user tv-input-icon"></i>
                                    <select class="tv-input">
                                        <option>25 – 70 години</option>
                                        <option>21 – 24 години (млад шофьор)</option>
                                        <option>18 – 20 години</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="small text-secondary fw-bold ms-2 mb-1">Резидент</label>
                                <div class="tv-input-wrapper">
                                    <i class="fa-solid fa-flag tv-input-icon"></i>
                                    <select class="tv-input">
                                        <option>България</option>
                                        <option>ЕС</option>
                                        <option>Великобритания</option>
                                        <option>Друга държава</option>
                                    </select>
                                </div>
                            </div>
                            <!-- Extras -->
                            <div class="col-12">
                                <label class="small text-secondary fw-bold ms-2 mb-1">Приоритети</label>
                                <div class="d-flex flex-wrap gap-2 mt-2">
                                    <button type="button" class="tv-chip-toggle priority-chip">
                                        <i class="fa-solid fa-leaf me-1"></i> Хибрид / Ел.
                                    </button>
                                    <button type="button" class="tv-chip-toggle priority-chip">
                                        <i class="fa-solid fa-gear me-1"></i> Автоматик
                                    </button>
                                    <button type="button" class="tv-chip-toggle priority-chip">
                                        <i class="fa-solid fa-users me-1"></i> 7+ места
                                    </button>
                                    <button type="button" class="tv-chip-toggle priority-chip">
                                        <i class="fa-solid fa-shield-halved me-1"></i> Пълно каско
                                    </button>
                                </div>
                            </div>
                            <div class="col-12 pt-2">
                                <a asp-controller="Cars" asp-action="Grid" class="tv-btn-primary w-100 py-2 d-inline-block text-center text-decoration-none">
                                    <i class="fa-solid fa-magnifying-glass me-2"></i> Виж налични коли
                                </a>
                                <div class="d-flex justify-content-between mt-2 small text-white-50">
                                    <span><i class="fa-solid fa-circle-check text-success me-1"></i> Безплатна отмяна по повечето оферти</span>
                                    <span><i class="fa-solid fa-clock text-info me-1"></i> Търсене за под 5 сек.</span>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </section>
        <!-- POPULAR PICKUP LOCATIONS -->
        <section class="pb-5">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="tv-section-title mb-0">Популярни локации за вземане</h2>
                <a class="tv-filter-link-more" asp-controller="Cars" asp-action="Grid">
                    Виж всички оферти <i class="fa-solid fa-arrow-right ms-1"></i>
                </a>
            </div>
            <div class="row g-3 g-md-4">
                <!-- София -->
                <div class="col-12 col-md-6 col-xl-3">
                    <article class="tv-kpi-card tv-card-panel h-100">
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <div>
                                <div class="small text-white-50 mb-1">
                                    <i class="fa-solid fa-plane-departure me-1"></i> Летище София (SOF)
                                </div>
                                <h3 class="h6 text-white mb-1">София &amp; Център</h3>
                            </div>
                            <span class="badge rounded-pill bg-sky-500 text-dark small">
                                40+ коли
                            </span>
                        </div>
                        <p class="small text-white-50 mb-3">
                            Идеално за бизнес и градски пътувания – икономични, седани и премиум SUV.
                        </p>
                        <div class="d-flex justify-content-between align-items-center small">
                            <span class="text-white-50">
                                <i class="fa-solid fa-tags me-1 text-success"></i> от €25/ден
                            </span>
                            <a class="tv-link-inline" asp-controller="Cars" asp-action="Grid">
                                Виж оферти <i class="fa-solid fa-arrow-right ms-1"></i>
                            </a>
                        </div>
                    </article>
                </div>
                <!-- Варна -->
                <div class="col-12 col-md-6 col-xl-3">
                    <article class="tv-kpi-card tv-card-panel h-100">
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <div>
                                <div class="small text-white-50 mb-1">
                                    <i class="fa-solid fa-plane-departure me-1"></i> Летище Варна (VAR)
                                </div>
                                <h3 class="h6 text-white mb-1">Варна &amp; Златни</h3>
                            </div>
                            <span class="badge rounded-pill bg-emerald-500 text-dark small">
                                Summer hit
                            </span>
                        </div>
                        <p class="small text-white-50 mb-3">
                            Перфектно за морска почивка – компактни автомобили и ванове за семейства.
                        </p>
                        <div class="d-flex justify-content-between align-items-center small">
                            <span class="text-white-50">
                                <i class="fa-solid fa-tags me-1 text-success"></i> от €30/ден
                            </span>
                            <a class="tv-link-inline" href="car-grid.html">
                                Виж оферти <i class="fa-solid fa-arrow-right ms-1"></i>
                            </a>
                        </div>
                    </article>
                </div>
                <!-- Бургас -->
                <div class="col-12 col-md-6 col-xl-3">
                    <article class="tv-kpi-card tv-card-panel h-100">
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <div>
                                <div class="small text-white-50 mb-1">
                                    <i class="fa-solid fa-plane-departure me-1"></i> Летище Бургас (BOJ)
                                </div>
                                <h3 class="h6 text-white mb-1">Слънчев бряг &amp; Созопол</h3>
                            </div>
                            <span class="badge rounded-pill bg-amber-400 text-dark small">
                                -20% early
                            </span>
                        </div>
                        <p class="small text-white-50 mb-3">
                            Морски курорти, all inclusive хотели и удобен достъп с рент-а-кар.
                        </p>
                        <div class="d-flex justify-content-between align-items-center small">
                            <span class="text-white-50">
                                <i class="fa-solid fa-tags me-1 text-success"></i> от €28/ден
                            </span>
                            <a class="tv-link-inline" href="car-grid.html">
                                Виж оферти <i class="fa-solid fa-arrow-right ms-1"></i>
                            </a>
                        </div>
                    </article>
                </div>
                <!-- Планина -->
                <div class="col-12 col-md-6 col-xl-3">
                    <article class="tv-kpi-card tv-card-panel h-100">
                        <div class="d-flex align-items-center justify-content-between mb-2">
                            <div>
                                <div class="small text-white-50 mb-1">
                                    <i class="fa-solid fa-mountain-sun me-1"></i> Банско, Пампорово, Боровец
                                </div>
                                <h3 class="h6 text-white mb-1">Планински дестинации</h3>
                            </div>
                            <span class="badge rounded-pill bg-indigo-500 text-white small">
                                4x4 / SUV
                            </span>
                        </div>
                        <p class="small text-white-50 mb-3">
                            4x4 SUV, ски багажници и зимни гуми за пълна безопасност през сезона.
                        </p>
                        <div class="d-flex justify-content-between align-items-center small">
                            <span class="text-white-50">
                                <i class="fa-solid fa-tags me-1 text-success"></i> от €40/ден
                            </span>
                            <a class="tv-link-inline" href="car-grid.html">
                                Виж оферти <i class="fa-solid fa-arrow-right ms-1"></i>
                            </a>
                        </div>
                    </article>
                </div>
            </div>
        </section>
        <!-- RECOMMENDED CARS (reuse grid-card style) -->
        <section class="pb-5">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="tv-section-title mb-0">Препоръчани оферти днес</h2>
                <div class="d-flex align-items-center gap-2">
                    <span class="text-white-50 small d-none d-md-inline">Базирано на рейтинг и цена</span>
                    <a class="tv-btn-outline-glass" asp-controller="Cars" asp-action="Grid">
                        Всички коли <i class="fa-solid fa-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
            <div class="row g-4">
                <!-- Toyota Yaris (from car-grid) -->
                <div class="col-md-6 col-xl-4">
                    <article class="tv-hotel-grid-card">
                        <div class="tv-hotel-grid-media">
                            <img alt="Toyota Yaris" class="tv-hotel-grid-img" src="https://scene7.toyota.eu/is/image/toyotaeurope/YAR0003_24_WEB:Large-Landscape?ts=1722500144555&amp;resMode=sharp2&amp;op_usm=1.75,0.3,2,0&amp;fmt=png-alpha" />
                            <span class="tv-grid-badge-top">Top deal</span>
                            <button class="tv-grid-fav-btn"><i class="fa-regular fa-heart"></i></button>
                            <div class="tv-grid-location-badge">
                                <i class="fa-solid fa-leaf text-success"></i> Еко
                            </div>
                        </div>
                        <div class="tv-hotel-grid-body">
                            <div class="tv-hotel-grid-header">
                                <h3 class="tv-hotel-grid-title">Toyota Yaris</h3>
                                <div class="tv-hotel-grid-rating">
                                    4.8 <i class="fa-solid fa-star"></i>
                                </div>
                            </div>
                            <div class="tv-grid-amenities">
                                <span class="tv-spec-item"><i class="fa-solid fa-user"></i> 4</span>
                                <span class="tv-spec-item"><i class="fa-solid fa-suitcase"></i> 1</span>
                                <span class="tv-spec-item"><i class="fa-solid fa-gear"></i> Ръчна</span>
                                <span class="tv-spec-item"><i class="fa-solid fa-gas-pump"></i> Бензин</span>
                            </div>
                            <p class="small text-white-50 mb-0 flex-grow-1">
                                Компактен и икономичен градски автомобил – идеален за София и кратки пътувания.
                            </p>
                            <div class="tv-hotel-grid-footer">
                                <div>
                                    <span class="tv-grid-price-label">Цена за ден</span>
                                    <span class="tv-grid-price-val">€35</span>
                                    <span class="d-block small text-success">Безплатна отмяна</span>
                                </div>
                                <a class="tv-btn-grid-action" asp-controller="Cars" asp-action="Details">
                                    Детайли <i class="fa-solid fa-arrow-right"></i>
                                </a>
                            </div>
                        </div>
                    </article>
                </div>
                <!-- Toyota Camry Hybrid -->
                <div class="col-md-6 col-xl-4">
                    <article class="tv-hotel-grid-card">
                        <div class="tv-hotel-grid-media">
                            <img alt="Toyota Camry Hybrid" class="tv-hotel-grid-img" src="https://di-uploads-pod7.dealerinspire.com/toyotachulavista/uploads/2023/09/2024-Toyota-Camry-Hybrid.png" />
                            <span class="tv-grid-badge-top" style="background: linear-gradient(135deg, #0ea5e9, #2563eb);">
                                Travelis Choice
                            </span>
                            <button class="tv-grid-fav-btn"><i class="fa-regular fa-heart"></i></button>
                            <div class="tv-grid-location-badge">
                                <i class="fa-solid fa-bolt text-warning"></i> Instant
                            </div>
                        </div>
                        <div class="tv-hotel-grid-body">
                            <div class="tv-hotel-grid-header">
                                <h3 class="tv-hotel-grid-title">Toyota Camry Hybrid</h3>
                                <div class="tv-hotel-grid-rating">
                                    4.9 <i class="fa-solid fa-star"></i>
                                </div>
                            </div>
                            <div class="tv-grid-amenities">
                                <span class="tv-spec-item"><i class="fa-solid fa-user"></i> 5</span>
                                <span class="tv-spec-item"><i class="fa-solid fa-suitcase"></i> 2</span>
                                <span class="tv-spec-item"><i class="fa-solid fa-gear"></i> Авто</span>
                                <span class="tv-spec-item"><i class="fa-solid fa-leaf"></i> Хибрид</span>
                            </div>
                            <p class="small text-white-50 mb-0 flex-grow-1">
                                Комфортен бизнес седан с нисък разход – подходящ за междуградски пътувания.
                            </p>
                            <div class="tv-hotel-grid-footer">
                                <div>
                                    <span class="tv-grid-price-label">Цена за ден</span>
                                    <span class="tv-grid-price-val text-info">€70</span>
                                    <span class="d-block small text-white-50">Вкл. 600 км · Пълно каско (доп.)</span>
                                </div>
                                <a class="tv-btn-grid-action" href="car-detail.html">
                                    Детайли <i class="fa-solid fa-arrow-right"></i>
                                </a>
                            </div>
                        </div>
                    </article>
                </div>
                <!-- SUV / Mountain -->
                <div class="col-md-6 col-xl-4">
                    <article class="tv-hotel-grid-card">
                        <div class="tv-hotel-grid-media">
                            <img alt="VW Tiguan" class="tv-hotel-grid-img" src="https://7cars.bg/wp-content/uploads/2024/05/1-18.jpg" />
                            <button class="tv-grid-fav-btn"><i class="fa-regular fa-heart"></i></button>
                            <div class="tv-grid-location-badge">
                                <i class="fa-solid fa-mountain"></i> 4x4
                            </div>
                        </div>
                        <div class="tv-hotel-grid-body">
                            <div class="tv-hotel-grid-header">
                                <h3 class="tv-hotel-grid-title">VW Tiguan 4x4</h3>
                                <div class="tv-hotel-grid-rating">
                                    4.7 <i class="fa-solid fa-star"></i>
                                </div>
                            </div>
                            <div class="tv-grid-amenities">
                                <span class="tv-spec-item"><i class="fa-solid fa-user"></i> 5</span>
                                <span class="tv-spec-item"><i class="fa-solid fa-suitcase"></i> 3</span>
                                <span class="tv-spec-item"><i class="fa-solid fa-gear"></i> Авто</span>
                                <span class="tv-spec-item"><i class="fa-solid fa-gas-pump"></i> Дизел</span>
                            </div>
                            <p class="small text-white-50 mb-0 flex-grow-1">
                                Просторен SUV със зимни гуми – идеален за ски уикенди и планински пътища.
                            </p>
                            <div class="tv-hotel-grid-footer">
                                <div>
                                    <span class="tv-grid-price-label">Цена за ден</span>
                                    <span class="tv-grid-price-val">€85</span>
                                    <span class="d-block small text-warning">
                                        <i class="fa-solid fa-triangle-exclamation me-1"></i> Остават 2 автомобила
                                    </span>
                                </div>
                                <a class="tv-btn-grid-action" asp-controller="Cars" asp-action="Details">
                                    Детайли <i class="fa-solid fa-arrow-right"></i>
                                </a>
                            </div>
                        </div>
                    </article>
                </div>
            </div>
        </section>
        <!-- BENEFITS + HOW IT WORKS -->
        <section class="pb-5">
            <div class="row g-4">
                <!-- Benefits -->
                <div class="col-lg-6">
                    <div class="tv-card-panel h-100">
                        <h2 class="tv-section-title mb-3">Защо да избереш Travelis Rent-a-car</h2>
                        <div class="row g-3">
                            <div class="col-12">
                                <div class="d-flex gap-3">
                                    <div class="tv-icon-pill">
                                        <i class="fa-solid fa-scale-balanced"></i>
                                    </div>
                                    <div>
                                        <h3 class="h6 text-white mb-1">Сравнение на реални оферти</h3>
                                        <p class="small text-white-50 mb-0">
                                            Сравняваме оферти от няколко партньорски компании, за да видиш ясни цени,
                                            условия и депозит на едно място.
                                        </p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="d-flex gap-3">
                                    <div class="tv-icon-pill">
                                        <i class="fa-solid fa-shield-halved"></i>
                                    </div>
                                    <div>
                                        <h3 class="h6 text-white mb-1">Прозрачни условия и защита</h3>
                                        <p class="small text-white-50 mb-0">
                                            Ясни правила за каско, щети и лимити. Преглеждаш всичко преди да завършиш резервацията.
                                        </p>
                                    </div>
                                </div>
                            </div>
                            <div class="col-12">
                                <div class="d-flex gap-3">
                                    <div class="tv-icon-pill">
                                        <i class="fa-solid fa-headset"></i>
                                    </div>
                                    <div>
                                        <h3 class="h6 text-white mb-1">Поддръжка 24/7</h3>
                                        <p class="small text-white-50 mb-0">
                                            Нашият екип и партньорите са на разположение при закъснял полет, повреда или промяна в плана.
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- How it works -->
                <div class="col-lg-6">
                    <div class="tv-card-panel h-100">
                        <h2 class="tv-section-title mb-3">Как протича резервацията</h2>
                        <ol class="list-unstyled tv-timeline">
                            <li class="tv-timeline-item">
                                <div class="tv-timeline-dot"></div>
                                <div class="tv-timeline-body">
                                    <h3 class="h6 text-white mb-1">1. Въведи локация и дати</h3>
                                    <p class="small text-white-50 mb-0">
                                        Избери летище или град, дати и часове за вземане и връщане. Добави предпочитания – автоматик, хибрид, 7+ места.
                                    </p>
                                </div>
                            </li>
                            <li class="tv-timeline-item">
                                <div class="tv-timeline-dot"></div>
                                <div class="tv-timeline-body">
                                    <h3 class="h6 text-white mb-1">2. Сравни оферти и условия</h3>
                                    <p class="small text-white-50 mb-0">
                                        Филтрирай по клас, цена и депозит. Виж ясно какво включва наемът – километри, каско, втори шофьор.
                                    </p>
                                </div>
                            </li>
                            <li class="tv-timeline-item">
                                <div class="tv-timeline-dot"></div>
                                <div class="tv-timeline-body">
                                    <h3 class="h6 text-white mb-1">3. Попълни данни на шофьора</h3>
                                    <p class="small text-white-50 mb-0">
                                        Въведи лични данни и данни от шофьорската книжка. Получаваш потвърждение и ваучер на имейл.
                                    </p>
                                </div>
                            </li>
                            <li class="tv-timeline-item">
                                <div class="tv-timeline-dot"></div>
                                <div class="tv-timeline-body">
                                    <h3 class="h6 text-white mb-1">4. Вземи колата от офис или летище</h3>
                                    <p class="small text-white-50 mb-0">
                                        На място подписваш договора, блокира се депозит и получаваш ключовете. Пътят те чака.
                                    </p>
                                </div>
                            </li>
                        </ol>
                        <div class="mt-3 d-flex justify-content-between align-items-center">
                            <span class="small text-white-50">
                                <i class="fa-solid fa-info-circle me-1"></i> Детайлите за наем са описани на
                                <a class="tv-link-inline" asp-controller="Cars" asp-action="Policies">страницата с политики</a>
                            </span>
                            <a class="tv-btn-outline-glass d-none d-md-inline-flex" asp-controller="Cars" asp-action="Booking">
                                Започни резервация
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
       
    </div>
    @section Scripts {
        <script>
                $(document).ready(function () {
                    // ЛОГИКА ЗА ЛОКАЦИИ (Избира се само ЕДНО)
                    $('.location-chip').click(function () {
                        $('.location-chip').removeClass('tv-chip-active');
                        $(this).addClass('tv-chip-active');
                    });

                    // ЛОГИКА ЗА ПРИОРИТЕТИ (Може да избереш МНОГО)
                    $('.priority-chip').click(function () {
                        // toggleClass добавя класа ако го няма, и го маха ако го има
                        $(this).toggleClass('tv-chip-active');
                    });
                });
        </script>
    }


</main>